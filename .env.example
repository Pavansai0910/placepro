# Razorpay Key ID (safe to expose on frontend — this is the public key)
# Get from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Note: RAZORPAY_KEY_SECRET must NEVER go in frontend env vars.
# This setup uses Razorpay Standard Checkout without a backend order:
# payments are captured and visible in your Razorpay dashboard.
